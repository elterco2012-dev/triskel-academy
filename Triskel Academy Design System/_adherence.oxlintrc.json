      "--font-sans",
      "--mobile-max-width",
      "--mod-funcional",
      "--mod-funcional-tint",
      "--mod-mat",
      "--mod-mat-tint",
      "--mod-reformer",
      "--mod-reformer-tint",
      "--modal-max-width",
      "--radius",
